# name: test/sql/flock.test
# description: PR-1 smoke test — extension loads and exports flock_version()
# group: [sql]

require flock

# The extension binary builds, loads, and the flock-named SQL surface is
# reachable. The actual semantics live in PR-2+.
query I
SELECT flock_version() IS NOT NULL;
----
true

# The flock_version() return is non-empty (CMake should set
# EXT_VERSION_FLOCK at build time; the fallback "unknown" is also
# acceptable for source builds without git tags).
query I
SELECT length(flock_version()) > 0;
----
true

# The vendored quack SQL surface is intact. PR-1 promises only that
# these names exist, not that all semantics are exercised here — that
# coverage lives in the vendored quack tests we'll wire up later.
statement ok
SELECT quack_check_token('sid', 'tok', 'tok');

statement ok
SELECT quack_nop_authorization('sid', 'SELECT 1');
