# name: test/sql/harbor.test
# description: PR-1 smoke + /quack runtime roundtrip (the regression
#              baseline for PR-2's architectural refactor)
# group: [sql]
#
# Verifies:
#   1. The harbor extension loads and exports harbor-named identifiers
#      (smoke surface — proves static-link + SQL-surface registration).
#   2. quack_serve starts a server, the wire format on POST /quack works
#      end-to-end (a quack-protocol client successfully attaches and
#      runs queries), and quack_stop tears it down cleanly.
#
# This file IS the regression harness for PR-2's HarborHttpServer
# extraction. When PR-2 dissolves QuackServer's embedded httplib::Server
# into a shared HarborHttpServer, every assertion in this file must
# remain green. Modeled on duckdb-quack's test/sql/rpc.test (same
# con1/con2 pattern); kept narrower to focus on what PR-2 might break.

require harbor

require httpfs

statement ok
LOAD harbor;

# ------------------------------------------------------------------
# Smoke surface — extension loaded, harbor-named identifiers reachable
# ------------------------------------------------------------------

query I
SELECT CASE WHEN harbor_version() IS NOT NULL THEN 1 ELSE 0 END;
----
1

query I
SELECT CASE WHEN length(harbor_version()) > 0 THEN 1 ELSE 0 END;
----
1

statement ok
SELECT quack_check_token('sid', 'tok', 'tok');

statement ok
SELECT quack_nop_authorization('sid', 'SELECT 1');

# ------------------------------------------------------------------
# /quack roundtrip — start server on con1, query from con2 over HTTP
# ------------------------------------------------------------------

set ignore_error_messages __none__

# Use an explicit non-default port (19494, not the default 9494) to
# minimize the chance of a stale process or a parallel job colliding
# with us. quack_serve accepts `quack:host:port`.
query III con1
CALL quack_serve('quack:localhost:19494', token='harbor-test-token');
----
quack:localhost:19494	http://localhost:19494	harbor-test-token

# Wait for the listener thread to finish binding. 500ms is conservative
# but cheap; the upstream test uses 100ms but flakiness in CI under
# load is more painful than 400ms of test time.
sleep 500 millisecond

# Successful query with the right token via direct quack_query.
# This exercises the full /quack request/response wire format —
# CONNECTION_REQUEST → CONNECTION_RESPONSE → PREPARE_REQUEST →
# PREPARE_RESPONSE → DISCONNECT_MESSAGE — encoded with the upstream
# BinarySerializer at the pinned compatibility version.
query I con2
FROM quack_query('quack:localhost:19494', 'SELECT 42', token='harbor-test-token')
----
42

# Auth failure: wrong token rejected. Verifies authentication callback
# resolution (quack_authentication_function setting → quack_check_token
# default → string compare) still works after our harbor-specific edits
# to quack_extension.cpp.
statement error con2
FROM quack_query('quack:localhost:19494', 'SELECT 42', token='wrong-token')
----
Authentication failed

# Secret-based auth: store token in a secret, omit from the call.
# Exercises the QuackSecret type registration.
statement ok con2
CREATE SECRET (TYPE quack, TOKEN 'harbor-test-token', SCOPE 'quack:localhost:19494')

query I con2
FROM quack_query('quack:localhost:19494', 'SELECT 42')
----
42

# Multi-row result — exercises the FETCH path.
query I con2
FROM quack_query('quack:localhost:19494', 'FROM range(5)')
----
0
1
2
3
4

# Larger result that exceeds one chunk — exercises FETCH chunking.
query I con2
SELECT max(range) FROM quack_query('quack:localhost:19494', 'FROM range(100000)')
----
99999

# Multi-statement state inside a single quack_query call (transactions
# work end-to-end — this is a property we want to guarantee survives
# the PR-2 refactor of session lifecycle). Idempotent setup so that a
# stale state from a previous run doesn't fail the test.
query I con2
FROM quack_query('quack:localhost:19494', 'DROP TABLE IF EXISTS harbor_test_t; CREATE TABLE harbor_test_t(i INT); INSERT INTO harbor_test_t VALUES (1), (2), (3); SELECT count(*) FROM harbor_test_t')
----
3

# Clean shutdown.
statement ok con1
CALL quack_stop('quack:localhost:19494')

# Repeat shutdown is idempotent (returns "no server found" but does not
# error).
statement ok con1
CALL quack_stop('quack:localhost:19494')

# After stop, queries fail with IO error (server is gone).
statement error con2
FROM quack_query('quack:localhost:19494', 'SELECT 42')
----
IO Error

# ------------------------------------------------------------------
# PR-4: cookie auth + CORS allow-list — SQL-testable surface
# ------------------------------------------------------------------
# The HTTP-level cookie roundtrip (login → cookie → /ddb/run, login
# page HTML, etc.) lives in scripts/golden-cookie-auth.sh. The block
# below covers what's testable via SQL alone: setting registration,
# default values, and the refuse-to-start invariants on
# harbor_cors_origins.

# New PR-4 settings exist with documented defaults.
query I
SELECT current_setting('harbor_auth_cookie_ttl_s')
----
43200

query I
SELECT current_setting('harbor_cors_origins')
----
(empty)

query I
SELECT current_setting('harbor_local_dev_mode')
----
false

# harbor_cookie_signing_key is intentionally NOT a setting (security
# review — would let any SQL caller mint cookies). Confirm it's
# absent from the SQL surface.
statement error
SELECT current_setting('harbor_cookie_signing_key')
----
unrecognized

# Refuse-to-start: harbor_cors_origins='*' must throw at harbor_serve
# time. SPEC §7 forbids wildcard-with-credentials.
statement ok
SET GLOBAL harbor_cors_origins='*'

statement error
CALL harbor_serve('quack:localhost:19495', token='harbor-cors-test')
----
harbor_cors_origins='*' is forbidden

# Reset to a sane value and confirm harbor_serve succeeds. Use a
# specific allowed origin (not the wildcard).
statement ok
SET GLOBAL harbor_cors_origins='https://app.example.com,http://localhost:3000'

query III con1
CALL harbor_serve('quack:localhost:19495', token='harbor-cors-test')
----
quack:localhost:19495	http://localhost:19495	harbor-cors-test

statement ok con1
CALL harbor_stop('quack:localhost:19495')

# v0.1.2 — harbor_stop() no-arg overload (issue #28). Single-server-
# per-process semantics make the no-arg form unambiguous: it stops
# whatever's currently running. Both forms must coexist.
query III con1
CALL harbor_serve('quack:localhost:19495', token='harbor-stop-noarg-test')
----
quack:localhost:19495	http://localhost:19495	harbor-stop-noarg-test

statement ok con1
CALL harbor_stop()

# Idempotent? When nothing is running, no-arg form should clearly
# error (not silently say "no server found" — that branch is for
# the URI-arg form which can be called speculatively).
statement error con1
CALL harbor_stop()
----
no server is currently running

# Refuse-to-start: malformed origin (has path) is rejected.
statement ok
SET GLOBAL harbor_cors_origins='https://app.example.com/admin'

statement error
CALL harbor_serve('quack:localhost:19495', token='harbor-cors-test')
----
must be scheme://host[:port]

# Refuse-to-start: bare hostname without scheme is rejected.
statement ok
SET GLOBAL harbor_cors_origins='app.example.com'

statement error
CALL harbor_serve('quack:localhost:19495', token='harbor-cors-test')
----
no scheme

# Refuse-to-start: non-http(s) scheme is rejected.
statement ok
SET GLOBAL harbor_cors_origins='ftp://app.example.com'

statement error
CALL harbor_serve('quack:localhost:19495', token='harbor-cors-test')
----
must use http or https scheme

# Reset for any later tests in the file.
statement ok
RESET GLOBAL harbor_cors_origins

# ------------------------------------------------------------------
# PR-5: /sql settings — SQL-testable surface
# ------------------------------------------------------------------
# The HTTP-level /sql behavior (NDJSON streaming, one-shot JSON,
# sessions, params, auth gates, type round-trips) lives in
# scripts/golden-sql-roundtrip.sh. The block below covers settings
# registration/defaults.

query I
SELECT current_setting('harbor_max_sessions')
----
1024

query I
SELECT current_setting('harbor_max_response_rows')
----
0

query I
SELECT current_setting('harbor_max_request_body_bytes')
----
268435456

# ------------------------------------------------------------------
# PR-6: admin handlers — SQL-testable surface
# ------------------------------------------------------------------
# The HTTP-level admin behavior (default-deny matrix, /whoami, /tables,
# /schema, /checkpoint, /sessions, /interrupt, /sql/cancel, CSRF +
# Content-Type + body-limit guards) lives in
# scripts/golden-admin-roundtrip.sh. The block below covers what's
# testable via SQL alone: setting registration + default.

query I
SELECT current_setting('harbor_allow_admin_without_authz')
----
false

# ------------------------------------------------------------------
# PR-7b: harbor_query_timeout_s — SQL-testable surface
# ------------------------------------------------------------------
# The HTTP-level timeout enforcement (sweeper, RAII watchdog, mid-stream
# QUERY_TIMEOUT NDJSON line, HTTP 504 pre-response) lands with the
# threading + wiring commit on this same branch. Today's foundation
# commit just registers the setting with the SPEC §9 default (0 = no
# limit).

query I
SELECT current_setting('harbor_query_timeout_s')
----
0
